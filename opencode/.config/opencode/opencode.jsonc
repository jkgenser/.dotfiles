{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false,
    },
  },
  "agent": {
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      // "model": "opencode-go/kimi-k2.5",
      // "model": "opencode/qwen3.6-plus-free",
      // "model": "opencode/kimi-k2.5",
      // "model": "opencode/nemotron-3-super-free",
      // "model": "opencode/claude-sonnet-4-6",
      // "model": "google-vertex/gemini-3-flash-preview",
      // "model": "opencode/minimax-m2.1",
      // "model": "opencode/claude-haiku-4-5",
      // "model": "opencode/gpt-5.1-codex-max",
    },
  },
  "provider": {
    // "google-vertex-anthropic": {
    //   "models": {
    //     "claude-opus-4-6@default": {
    //       "options": {},
    //     },
    //   },
    // },
    "google-vertex": {
      "models": {
        "gemini-3.0-flash-preview": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 2048,
            },
          },
        },
        "gemini-3.1-pro-preview": {
          "options": {
            "thinking": {
              "type": "enabled",
              "nbudgetTokens": 1024,
            },
          },
        },
      },
    },
    "opencode": {
      "models": {
        // "claude-opus-4-6": {
        //   "options": {
        //     "thinking": {
        //       "type": "enabled",
        //       "budgetTokens": 16000,
        //     },
        //   },
        // },
        "claude-opus-4-5": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000,
            },
          },
        },
        "claude-sonnet-4-5": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000,
            },
          },
        },
        // "claude-sonnet-4-6": {
        //   "options": {
        //     "thinking": {
        //       "type": "enabled",
        //       "budgetTokens": 16000,
        //     },
        //   },
        // },
      },
    },
  },
  // "provider": {
  //   "opencode": {
  //     "models": {
  //       "claude-sonnet-4-5": {
  //         "options": {
  //           "thinking": {
  //             "type": "enabled",
  //             "budgetTokens": 16000,
  //           },
  //         },
